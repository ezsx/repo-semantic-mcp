SEMANTIC_MCP_COLLECTION_PREFIX=repo_semantic
SEMANTIC_MCP_INDEX_SCHEMA_VERSION=1

# GPU profile: TEI on CUDA with the target multilingual model.
SEMANTIC_MCP_EMBEDDING_BACKEND=tei_http
SEMANTIC_MCP_EMBEDDING_MODEL=BAAI/bge-m3

# TEI container image/model settings
SEMANTIC_MCP_TEI_IMAGE=ghcr.io/huggingface/text-embeddings-inference:cuda-1.9
SEMANTIC_MCP_TEI_MODEL_ID=BAAI/bge-m3
SEMANTIC_MCP_TEI_PORT=8081
SEMANTIC_MCP_TEI_DTYPE=float16

# Needed only for tei_http when not using the bundled compose service
SEMANTIC_MCP_TEI_URL=

SEMANTIC_MCP_TRANSPORT=http
SEMANTIC_MCP_HTTP_PORT=8011

SEMANTIC_MCP_WATCH_ENABLED=1
SEMANTIC_MCP_WATCH_DEBOUNCE_SEC=3
SEMANTIC_MCP_AUTO_INDEX_ON_START=1
SEMANTIC_MCP_EMBED_BATCH_DOCS=32
SEMANTIC_MCP_EMBED_BATCH_CHARS=18000
SEMANTIC_MCP_MAX_CHUNK_CHARS=1000
SEMANTIC_MCP_QDRANT_PORT=6333
SEMANTIC_MCP_LOG_LEVEL=info
