SEMANTIC_MCP_COLLECTION_PREFIX=repo_semantic
SEMANTIC_MCP_INDEX_SCHEMA_VERSION=1
SEMANTIC_MCP_PROFILE_NAME=cpu_e5

# fastembed_local | tei_http
SEMANTIC_MCP_EMBEDDING_BACKEND=tei_http
SEMANTIC_MCP_EMBEDDING_MODEL=intfloat/multilingual-e5-small
SEMANTIC_MCP_QUERY_TEMPLATE=query: {query}
SEMANTIC_MCP_DOCUMENT_PREFIX=passage: 

# Модель и внешний порт TEI-контейнера
SEMANTIC_MCP_TEI_MODEL_ID=intfloat/multilingual-e5-small
SEMANTIC_MCP_TEI_PORT=8081

# Нужен только для tei_http, внутри docker-compose по умолчанию http://tei:80
SEMANTIC_MCP_TEI_URL=
SEMANTIC_MCP_TEI_QUERY_PROMPT_NAME=
SEMANTIC_MCP_TEI_DOCUMENT_PROMPT_NAME=

# http для контейнерного shared deployment, stdio для локального запуска
SEMANTIC_MCP_TRANSPORT=http
SEMANTIC_MCP_HTTP_PORT=8011

SEMANTIC_MCP_WATCH_ENABLED=1
SEMANTIC_MCP_WATCH_DEBOUNCE_SEC=3
SEMANTIC_MCP_AUTO_INDEX_ON_START=1
SEMANTIC_MCP_EMBED_BATCH_DOCS=24
SEMANTIC_MCP_EMBED_BATCH_CHARS=12000
SEMANTIC_MCP_MAX_CHUNK_CHARS=800
SEMANTIC_MCP_QDRANT_PORT=6333
SEMANTIC_MCP_LOG_LEVEL=info
